{
  "name": "promptos-vscode",
  "publisher": "AniketJoarder",
  "displayName": "PromptOS - Prompt Refinement",
  "description": "Refine prompts before sending to AI coding assistants. Tracks efficiency, skill decay, and AI dependency — right in your editor.",
  "version": "0.2.1",
  "repository": { "type": "git", "url": "https://github.com/AniketJoarder/PromptOs" },
  "keywords": ["prompt", "ai", "copilot", "gemini", "claude", "refine", "productivity"],
  "engines": { "vscode": "^1.77.0" },
  "categories": ["Other", "Machine Learning"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "promptos",
          "title": "PromptOS",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "promptos": [
        { "type": "webview", "id": "promptos.sidebar", "name": "Refine Prompt" }
      ]
    },
    "commands": [
      {
        "command": "promptos.startSession",
        "title": "PromptOS: Start Refinement Session"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p tsconfig.json && npx esbuild src/webview/index.tsx --bundle --outfile=out/webview.js --external:vscode --loader:.tsx=tsx",
    "watch": "tsc -watch -p tsconfig.json"
  },
  "dependencies": {
    "@google/generative-ai": "^0.11.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.77.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "^5",
    "esbuild": "^0.21.0",
    "react": "^18",
    "react-dom": "^18"
  }
}
