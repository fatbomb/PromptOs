{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "outDir": ".",
    "rootDir": ".",
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["content.ts"],
  "exclude": ["node_modules"]
}
