{
  "manifest_version": 3,
  "name": "PromptOS",
  "version": "0.1.0",
  "description": "PromptOS Copilot — your AI coding companion for Claude and ChatGPT",
  "permissions": ["storage", "activeTab", "scripting", "clipboardWrite", "tabs"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://prompt-os-dusky.vercel.app/*",
    "https://prompt-os-dashboard.vercel.app/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://prompt-os-dashboard.vercel.app/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PromptOS"
  },
  "web_accessible_resources": [
    {
      "resources": ["overlay.css"],
      "matches": [
        "https://claude.ai/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ]
    }
  ]
}
